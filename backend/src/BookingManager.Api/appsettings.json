{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Issuer": "BookingManager.Api",
    "Audience": "BookingManager.Client",
    "ExpiryMinutes": 60,
    "SigningKey": "dev-only-signing-key-change-me-0123456789abcdef"
  },
  "SeedAdmin": {
    "Email": "admin@bookingmanager.local",
    "Password": "Admin123!"
  },
  "RateLimiting": {
    "Auth": { "PermitLimit": 5 },
    "BookingWrite": { "PermitLimit": 10 },
    "Reads": { "PermitLimit": 100 },
    "Global": { "PermitLimit": 200 }
  },
  "Frontend": {
    "Origin": "http://localhost:3000"
  }
}
